%%{ init: { 'flowchart': { 'curve': 'basis' } } }%%
graph LR

    %% ---------- FACTS: Past tense -------------------------------------------

    %% Domain Event is a FACT that changed the business (i.e., payment of $10 received)
    %% TEST: it has happened AND consequence inevitable
    classDef domain-event fill: orange, stroke: magenta, color: black

    %% A View IMPRESSED upon an active structure to elicit behavior: fact presentation (i.e., presented menu )
    %% TEST: it was shown AND actor is reacting
    classDef read-model fill: green, stroke: white, color: white

    %% ---------- BEHAVIOR ----------------------------------------------------

    %% Business Process, a single unit of behavior an active structure owns (i.e., seating customer for hostess)
    %% TEST: always OR inevitably TRIGGERS a specific EVENT (i.e., causes next fact)
    classDef actor-policy fill: pink, stroke: green, color: black

    %% Command is an active interaction WANTING an EVENT to happen: has a source (issuer),
    %% destination (provider), and optional response (OK, NO, none)
    %% Explanation: Act of policy manifestation TO CHANGE things (i.e., event is wanted)
    %% TEST: from actor to recipient to cause an event (i.e., waitress to cook "make me sandwich")
    classDef actor-command fill: blue, stroke: white, color: yellow

    %% (OPTIONAL) Query, a request for inevitable read model;
    %% (a non-event command idea) must be acknowledged and responded to
    %% TEST: active structure produced read model (i.e., waitress responded by giving menu)
    classDef actor-query fill: turquoise, stroke: red, color: black

    %% ---------- ACTIVE STRUCTURE --------------------------------------------

    %% Actor, an animated behavior owner (set of policies, i.e., job description) with data and state
    %% TEST: reads model, issues commands and queries
    classDef actor fill: yellow, stroke: black, color: black

    %% Aggregate: a synthetic actor: data is repository, behavior is actions
    %% TEST: Aggregates constructs together to formulate a clerk
    classDef aggregate fill: yellow, stroke: red, color: black

    %% External System: an active structure outside domain's control
    %% TEST: immutable nature to the team (i.e., like a delivery service to a waitress)
    classDef external-system fill: blueviolet, stroke: blue, color: white

    %% ---------- CONFLICT RESOLUTION -----------------------------------------

    classDef hotspot fill: #ef4444, stroke: #b91c1c, color: #fff

    %% ------------------------------------------------------------------------

    %% ~~~~~~~~~~ The Eventstorming Ceremony ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    %% It is 1922! Claude and Vadim observe an old cowboy town: "this needs some steam"

    %% STEP 1: Big Picture: Eventstorming: What all happened in our business y'all?!
    %% In what ORDER did it all happen?
    %% What groups events bunch up together in? (boundaries)
    %% Description: Place all domain events (orange) in chronological order left to right.
    %%   Test each with SVO and "it happened AND consequence inevitable."
    %%   Place hotspots (red) for conflicts and unknowns. Nothing else.
    %%   1922 rule: everything must be physical -- paper, people, cabinets.
    %%   Brainstorm until no more events come to mind, then vote to stop.

    %% Theory: SVO
    %% EVENT: [Subject (omitted: to be discovered later)] VERB (past tense) OBJECT (to be extracted later)
    %% Example: [Claude] ATE a CAKE

    %% STEP 2: Expansion (i.e., SVO expansion)
    %% Event to read mode (i.e., payload)
    %% Subject to event (i.e., actor)

    %%  Object is a read model: green presentation
    %%  Event      ->       Event
    %%    |                   |
    %%  Read model          Read model

    %%  Subject is an actor: White Question Mark if unknown; leave it so
    %%  Subject -> Event

    %% STEP 3: Cause and Effect: The fundamental Theorems of ES

    %% A. What Caused this Event? - first fundament theorem of ES
    %% Remember, command prompts action on actor - (causality theorem)
    %% Command -> Subject -> Event

    %% B. What Policy (rule) Command Conforms to? - second fundamental theorem of ES
    %% Remember, policy qualifiers are only: ALWAYS or IMMEDIATELY - (inevitability theorem)
    %% Policy -> Command

    %% STEP 4: Aggregation (i.e., software design)
    %% --------------------------------------------------
    %% | Aggregate: Clerk Bobby, does database adapters |
    %% |------------------------------------------------|
    %% | policy 1              |  read model A          |
    %% | policy 2              |  read model B          |
    %% | policy 3              |  entity C              |
    %% | policy 4              |                        |
    %% --------------------------------------------------

    %% viola!

    %% ========== STORE MEMORY ================================================

    subgraph Domain["Domain Boundary"]
        StoreMemoryCmd["Save THIS<br/>Memory<br/>For me"]:::actor-command
        Hippocampus["Hippocampus"]:::external-system
        RequestedSave["Requested<br/>Saved"]:::domain-event
        Memory["Memory"]:::read-model
        SavedMemory["Saved<br/>Memory"]:::domain-event
        SavedMemoryObj["Saved<br/>Memory<br/>(confirmed)"]:::read-model
        RejectedSave["Rejected<br/>Memory<br/>Save"]:::domain-event
        RejectedMemory["Rejected<br/>Memory"]:::read-model
    end

    subgraph Adapter["Inner Adapter Layer"]
        subgraph MemDataAdapterAgg["Memory-Data Adapter — Job Description"]
            AlwaysAcceptPolicy["Whenever Memory Arises<br/>Always and Immediately<br/>Command it Saved"]:::actor-policy
            AlwaysTranslateOutPolicy["Whenever Memory is Saving<br/>Always and Immediately<br/>Translate it to a DTO"]:::actor-policy
            AlwaysTranslateInPolicy["Whenever DTO-In Arrives<br/>Always and Immediately<br/>Translate it Back"]:::actor-policy
            AlwaysTranslateErrPolicy["Whenever DTO-In Arrives<br/>Always and Immediately<br/>Translate it Back"]:::actor-policy
            AlwaysConfirmPolicy["Whenever Translation Completes<br/>Always and Immediately<br/>Confirm the Result"]:::actor-policy
        end
        subgraph MemDataAdapterCmds["Memory-Data Adapter — Local Commands"]
            TranslateToDataCmd["Translate Memory Domain Object<br/>to Data Transfer Object for Port"]:::actor-command
            TranslateToMemoryCmd["Translate DTO<br/>to Domain Object"]:::actor-command
        end
        ConfirmResultCmd["Confirm Save<br/>Result"]:::actor-command
        MemoryDataAdapter["Memory-Data<br/>Adapter"]:::actor
        TranslatedMemory["Translated-Out"]:::domain-event
        TranslatedError["Translated<br/>Error"]:::domain-event
        TranslatedData["Translated-In"]:::domain-event
    end

    subgraph ACL-Core["Port"]
        DataPort["Data<br/>Port"]
    end

    subgraph Driver["Outer Adapter Layer"]
        SQLiteDriver["SQLite<br/>Driver"]:::actor
        subgraph SQLiteDriverGWT["SQLite Driver — Given-When-Then"]
            %% Policy 1: Persist (outbound)
            AlwaysPersistPolicy["Whenever DTO Arrives<br/>Always and Immediately<br/>Persist it"]:::actor-policy
            TranslateDtoToSqlCmd["Translate DTO<br/>to Prepared Statement"]:::actor-command
            DtoIn["DTO<br/>(in)"]:::read-model
            DtoOut["DTO<br/>Persisted<br/>(out)"]:::read-model
            DtoErr["DTO<br/>ERROR<br/>(out)"]:::read-model
            RequestedPersistence["Requested<br/>Persistence"]:::domain-event
            SqlStatement["Prepared<br/>Statement"]:::read-model
            %% Transaction ID: domain construct, links input DTO to output Query Result
            TransactionId["Transaction<br/>ID"]:::read-model
            %% Policy 2: Receive (inbound) -- consolidated, one output model
            AlwaysReceivePolicy["Whenever SQLite Responds<br/>Always and Immediately<br/>Receive and Translate"]:::actor-policy
            TranslateSqlToDtoCmd["Translate SQL Result<br/>to DTO"]:::actor-command
            ReceivedResult["Received<br/>Result"]:::domain-event
            ReceivedError["Received<br/>Error"]:::domain-event
        end
        SQLiteDriverGWT --- SQLiteDriver
    end

    subgraph Infrastructure["Infrastructure Boundary"]
        SQLite["SQLite"]:::external-system
        subgraph SQLiteGWT["SQLite — Given-When-Then"]
            %% Given: Prepared Statement (input model)
            PreparedStatement["Prepared<br/>Statement"]:::read-model
            %% When: Policy → Command
            AlwaysExecutePolicy["Whenever SQL Statement Arrives<br/>Always and Immediately<br/>Execute it"]:::actor-policy
            ExecuteSqlCmd["Execute this<br/>SQL Statement"]:::actor-command
            %% Then (happy): Event → Model
            PersistedData["Persisted"]:::domain-event
            SqlRecord["SQL<br/>Record"]:::read-model
            %% Then (failure): Event → Model
            FailedPersistence["Failed<br/>Persistence"]:::domain-event
            SqlError["SQL<br/>Error"]:::read-model
        end
        SQLiteGWT --- SQLite
    end

%% Noman land is empty!

    %% Flow (time order, left to right)

    Hippocampus --> StoreMemoryCmd
    StoreMemoryCmd --> MemoryDataAdapter
    MemoryDataAdapter --> RequestedSave
    RequestedSave --- Memory

    %% Command down
    AlwaysAcceptPolicy --> MemoryDataAdapter
    AlwaysTranslateOutPolicy --> MemoryDataAdapter

    MemoryDataAdapter --> TranslateToDataCmd
    TranslateToDataCmd --> MemoryDataAdapter

    RequestedSave --> TranslatedMemory

    MemoryDataAdapter --- TranslatedMemory

    %% Archimate: Inner adapter uses Data Port; SQLite Driver serves Data Port
    MemoryDataAdapter --> DataPort
    SQLiteDriver --> |"Serves(Data Persistence)"| DataPort

    %% SQLite Driver GWT Policy 1: Policy → Command → (Model) → Event → (Model)
    AlwaysPersistPolicy --- DtoIn
    DtoIn--> TranslateDtoToSqlCmd
    TranslateDtoToSqlCmd  --- SqlStatement
    SqlStatement --> RequestedPersistence

    %% Transaction ID links domain-facing models across the two policies
    DtoIn --- TransactionId
    TransactionId --- DtoOut
    TransactionId --- DtoErr

    %% Integration command: outer adapter --> infrastructure (through aggregate)
    SQLiteDriver -.-> |"Access(Query/Command)"| SQLite

    %% SQLite GWT: Policy → Command → (Model) → Event → (Model)
    AlwaysExecutePolicy --> ExecuteSqlCmd
    ExecuteSqlCmd --- PreparedStatement
    PreparedStatement --> PersistedData
    PersistedData --- SqlRecord
    PreparedStatement --> FailedPersistence
    FailedPersistence --- SqlError

    %% SQLite Driver GWT Policy 2: Policy → Command → Event → (Model)
    TranslateSqlToDtoCmd --- DtoOut
    DtoOut --> ReceivedResult
    TranslateSqlToDtoCmd --- DtoErr
    DtoErr--> ReceivedError
    AlwaysReceivePolicy  --> TranslateSqlToDtoCmd

    %% Inner adapter receives through Data Port (not yet GWT-ified)
    AlwaysTranslateInPolicy --> MemoryDataAdapter
    MemoryDataAdapter --> TranslateToMemoryCmd
    TranslateToMemoryCmd --> MemoryDataAdapter
    MemoryDataAdapter --- TranslatedData
    TranslatedData --> SavedMemory

    %% Integration command: inner adapter --> domain (confirm result)
    AlwaysConfirmPolicy --> MemoryDataAdapter
    MemoryDataAdapter --> ConfirmResultCmd
    ConfirmResultCmd --> Hippocampus
    SavedMemory --> Hippocampus
    SavedMemoryObj --- SavedMemory

    %% Failure fork -- absorbed into SQLite GWT chain above

    %% Failure return path -- absorbed into SQLite Driver GWT Policy 2 above

    %% Failure through Data Port to inner adapter (not yet GWT-ified)
    AlwaysTranslateErrPolicy --> MemoryDataAdapter
    MemoryDataAdapter --> TranslateToMemoryCmd
    TranslateToMemoryCmd --> MemoryDataAdapter
    MemoryDataAdapter --- TranslatedError

    %% Failure completes at domain (same integration command, different payload)
    TranslatedError --> RejectedSave
    RejectedSave --> Hippocampus
    RejectedMemory --- RejectedSave
