%%{ init: { 'flowchart': { 'curve': 'basis' } } }%%
graph LR

    %% ========== STEP 3 SNAPSHOT: Cause and Effect ==============================
    %% Captured at the end of Step 3 (Cause and Effect -- the Two Fundamental Theorems)
    %% All 11 events now have commands (blue) and policies (pink).
    %% Discovery: the entire ACL is a synchronous blocking pipeline.
    %% Every policy is "Always and Immediately." The customer stands at the counter.
    %% Failure path mirrors happy path -- same commands, same policies, different payloads.
    %% Trivial case: uniform blocking, single-event commands, no conditional policies.

    classDef domain-event fill: orange, stroke: magenta, color: black
    classDef read-model fill: green, stroke: white, color: white
    classDef actor-policy fill: pink, stroke: green, color: black
    classDef actor-command fill: blue, stroke: white, color: yellow
    classDef actor-query fill: turquoise, stroke: red, color: black
    classDef actor fill: yellow, stroke: black, color: black
    classDef aggregate fill: yellow, stroke: red, color: black
    classDef external-system fill: blueviolet, stroke: blue, color: white
    classDef hotspot fill: #ef4444, stroke: #b91c1c, color: #fff

    subgraph Domain["Domain Boundary"]
        direction LR
        AlwaysAcceptPolicy["Whenever Memory Arises<br/>Always and Immediately<br/>Command it Saved"]:::actor-policy
        StoreMemoryCmd["Save THIS<br/>Memory<br/>For me"]:::actor-command
        Hippocampus["Hippocampus"]:::external-system
        RequestedSave["Requested<br/>Saved"]:::domain-event
        Memory["Memory"]:::read-model
        AlwaysConfirmPolicy["Whenever Translation Completes<br/>Always and Immediately<br/>Confirm the Save"]:::actor-policy
        ConfirmSavedCmd["Confirm Memory<br/>Saved"]:::actor-command
        SavedMemory["Saved<br/>Memory"]:::domain-event
        HippocampusIn["Hippocampus<br/>(In)"]:::external-system
        SavedMemoryObj["Saved<br/>Memory<br/>(confirmed)"]:::read-model
        AlwaysConfirmErrPolicy["Whenever Translation Completes<br/>Always and Immediately<br/>Confirm the Save"]:::actor-policy
        ConfirmRejectedCmd["Confirm Memory<br/>Saved"]:::actor-command
        RejectedSave["Rejected<br/>Memory<br/>Save"]:::domain-event
        HippocampusErr["Hippocampus<br/>(Err)"]:::external-system
        RejectedMemory["Rejected<br/>Memory"]:::read-model
    end

    subgraph Adapter["Inner Adapter Layer"]
        direction LR
        AlwaysTranslateOutPolicy["Whenever Memory is Saving<br/>Always and Immediately<br/>Translate it to a DTO"]:::actor-policy
        TranslateToDataCmd["Translate Memory Domain Object<br/>to Data Transfer Object for Port"]:::actor-command
        MemoryDataAdapter["Memory-Data<br/>Adapter"]:::actor
        TranslatedMemory["Translated-Out"]:::domain-event
        AlwaysTranslateInPolicy["Whenever DTO-In Arrives<br/>Always and Immediately<br/>Translate it Back"]:::actor-policy
        TranslateToMemoryCmd["Translate DTO<br/>to Domain Object"]:::actor-command
        MemoryDataAdapterIn["Memory-Data<br/>Adapter<br/>(In?)"]:::actor
        TranslatedData["Translated-In"]:::domain-event
        AlwaysTranslateErrPolicy["Whenever DTO-In Arrives<br/>Always and Immediately<br/>Translate it Back"]:::actor-policy
        TranslateErrorCmd["Translate DTO<br/>to Domain Object"]:::actor-command
        MemoryDataAdapterErr["Memory-Data<br/>Adapter<br/>(Err?)"]:::actor
        TranslatedError["Translated<br/>Error"]:::domain-event
    end

    subgraph ACL-Core["Port"]
        direction TB
        Port-Hole-Out["Port Channel Out"]
        MemoryDataOut["Data<br/>Memory<br/>(DTO-Out)"]:::read-model
        Port-Hole-In["Port Channel In"]
        MemoryDataIn["Saved<br/>Data<br/>Memory<br/>(a DTO-In?)"]:::read-model
        ErrorDTO["Error<br/>DTO"]:::read-model
    end

    subgraph Driver["Outer Adapter Layer"]
        direction LR
        AlwaysPersistPolicy["Whenever DTO Arrives<br/>Always and Immediately<br/>Persist it"]:::actor-policy
        PersistDataCmd["Persist this DTO<br/>as SQL"]:::actor-command
        DataSqlAdapter["Data-SQL<br/>Adapter"]:::actor
        AlwaysReceiveResultPolicy["Whenever Result is Returned<br/>Always and Immediately<br/>Receive it"]:::actor-policy
        ReturnResultCmd["Return this<br/>Result"]:::actor-command
        DataSqlAdapterResult["Data-SQL<br/>Adapter<br/>(Result?)"]:::actor
        RequestedPersistence["Requested<br/>Persistence"]:::domain-event
        SqlStatement["SQL<br/>Statement"]:::read-model
        ReceivedResult["Received<br/>Result"]:::domain-event
        QueryResult["Query<br/>Result"]:::read-model
        AlwaysReceiveErrorPolicy["Whenever Result is Returned<br/>Always and Immediately<br/>Receive it"]:::actor-policy
        ReturnErrorCmd["Return this<br/>Result"]:::actor-command
        DataSqlAdapterErr["Data-SQL<br/>Adapter<br/>(Err?)"]:::actor
        ReceivedError["Received<br/>Error"]:::domain-event
        SqlErrorReceived["SQL<br/>Error<br/>(received)"]:::read-model
    end

    subgraph Infrastructure["Infrastructure Boundary"]
        direction LR
        AlwaysExecutePolicy["Whenever SQL Statement Arrives<br/>Always and Immediately<br/>Execute it"]:::actor-policy
        ExecuteSqlCmd["Execute this<br/>SQL Statement"]:::actor-command
        SQLite["SQLite"]:::external-system
        AlwaysExecutePolicyErr["Whenever SQL Statement Arrives<br/>Always and Immediately<br/>Execute it"]:::actor-policy
        ExecuteSqlCmdErr["Execute this<br/>SQL Statement"]:::actor-command
        SQLiteErr["SQLite<br/>(Err)"]:::external-system
        PersistedData["Persisted"]:::domain-event
        FailedPersistence["Failed<br/>Persistence"]:::domain-event
        SqlRecord["SQL<br/>Record"]:::read-model
        SqlError["SQL<br/>Error"]:::read-model
    end

%% Noman land is empty!

    %% Flow (time order, left to right)

    AlwaysAcceptPolicy --> StoreMemoryCmd
    StoreMemoryCmd --> RequestedSave
    Hippocampus --> RequestedSave
    RequestedSave --- Memory

    %% Command down
    AlwaysTranslateOutPolicy --> TranslateToDataCmd
    TranslateToDataCmd --> TranslatedMemory
    RequestedSave --> TranslatedMemory

    MemoryDataAdapter --- TranslatedMemory
    TranslatedMemory --- MemoryDataOut

    %% Port traversal out (gate)
    TranslatedMemory --> Port-Hole-Out
    Port-Hole-Out --> RequestedPersistence

    %% Port control arrangement
    Port-Hole-Out ~~~~~~~~~~ Port-Hole-In
    Port-Hole-Out o--o MemoryDataOut
    MemoryDataIn o--o Port-Hole-In
    ErrorDTO o--o Port-Hole-In

    %% Outer Adapter
    AlwaysPersistPolicy --> PersistDataCmd
    PersistDataCmd --> RequestedPersistence
    RequestedPersistence --- MemoryDataOut
    DataSqlAdapter --- RequestedPersistence
    RequestedPersistence --- SqlStatement

    %% Command down to metal
    AlwaysExecutePolicy --> ExecuteSqlCmd
    ExecuteSqlCmd --> PersistedData
    RequestedPersistence --> PersistedData

    %% Infrastructure bedrock
    SQLite --- PersistedData
    PersistedData --- SqlRecord

    %% Command back up
    AlwaysReceiveResultPolicy --> ReturnResultCmd
    ReturnResultCmd --> ReceivedResult
    PersistedData --> ReceivedResult

    DataSqlAdapterResult --- ReceivedResult
    ReceivedResult --- QueryResult

    %% Traverse port in (gate)
    ReceivedResult --> Port-Hole-In
    Port-Hole-In --> TranslatedData

    AlwaysTranslateInPolicy --> TranslateToMemoryCmd
    TranslateToMemoryCmd --> TranslatedData
    ReceivedResult --- MemoryDataIn
    MemoryDataAdapterIn --- TranslatedData
    TranslatedData --- MemoryDataIn
    TranslatedData --> SavedMemory

    AlwaysConfirmPolicy --> ConfirmSavedCmd
    ConfirmSavedCmd --> SavedMemory
    SavedMemory --> HippocampusIn
    SavedMemoryObj --- SavedMemory

    RequestedPersistence ~~~~~~ ReceivedResult
    ReceivedResult ~~~~~~ ReceivedError

    %% Failure fork
    AlwaysExecutePolicyErr --> ExecuteSqlCmdErr
    ExecuteSqlCmdErr --> FailedPersistence
    RequestedPersistence --> FailedPersistence
    SQLiteErr --- FailedPersistence
    FailedPersistence --- SqlError

    %% Failure return path
    PersistedData ~~~~~~ FailedPersistence
    AlwaysReceiveErrorPolicy --> ReturnErrorCmd
    ReturnErrorCmd --> ReceivedError
    FailedPersistence --> ReceivedError
    DataSqlAdapterErr --- ReceivedError
    ReceivedError --- SqlErrorReceived

    ReceivedError --- ErrorDTO

    %% Failure through port to inner adapter
    ReceivedError --> Port-Hole-In
    AlwaysTranslateErrPolicy --> TranslateErrorCmd
    TranslateErrorCmd --> TranslatedError
    Port-Hole-In --> TranslatedError
    MemoryDataAdapterErr --- TranslatedError
    TranslatedError --- ErrorDTO

    TranslatedMemory ~~~ TranslatedError
    TranslatedError ~~~~ TranslatedData

    %% Failure completes at domain
    AlwaysConfirmErrPolicy --> ConfirmRejectedCmd
    ConfirmRejectedCmd --> RejectedSave
    TranslatedError --> RejectedSave
    RejectedSave --> HippocampusErr
    RejectedMemory --- RejectedSave

    RequestedSave ~~~ RejectedSave
    RejectedSave ~~~~~ SavedMemory
